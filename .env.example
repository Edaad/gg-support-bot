# Copy to .env — never commit real secrets.

# Core
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Test bot (python run_test_bot.py) — separate BotFather token for staging /deposit in a group.
# Sets BOT_TEST_WORKER=1 automatically. Uses club_payment_* (v2); no MTProto dm_gc listener.
TELEGRAM_TEST_BOT_TOKEN=your_test_bot_token_from_botfather
# TEST_BOT_TOKEN=...   # alias for TELEGRAM_TEST_BOT_TOKEN
# BOT_USE_PAYMENT_V2=1   # default: club_payment_* (v2). Set to 0 to use legacy payment_* tables.
# First-time deposit linking (dashboard: Club → Deposit methods → Venmo/Zelle):
#   Enable per method; see docs/VENMO_GROUP_BINDING.md
#   Migration: python migrate_club_payment_first_time_linking.py
# Staff: /unbindmethod — clear all payment-method links for that chat
# First-time deposit linking (venmo/zelle): configure per method in dashboard Club → Deposit methods.

# GGCashier (staff cashout wizard) — separate bot from BotFather
TELEGRAM_CASHIER_BOT_TOKEN=your_cashier_bot_token_from_botfather

# Zapier → Glide Cashouts (GGCashier completion). Omit in dev to skip POST.
# ZAPIER_CASHOUT_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/20524789/4ogfszq/

# Bot worker stderr logging (defaults to INFO — support bot + GGCashier cashier worker)
# LOG_LEVEL=INFO

# GGCashier: extra DEBUG lines for every callback + conversation state (default off)
# CASHIER_VERBOSE_LOGS=true

# Telegram MTProto (User API) — required for /gc group creation via Telethon
# Create an app at https://my.telegram.org/apps
TG_API_ID=12345678
TG_API_HASH=your_api_hash_here

# MTProto on the bot worker: ON by default. Set false/0/no/off to disable ALL Telethon
# (dm_gc listener + contact save). Use on Heroku while running local MTProto scripts
# (invite-link backfill, player-binding backfill) so sessions are not duplicated.
# GC_MTPROTO_ENABLED=false

# Outgoing /gc in admin→player DMs: ON by default. Set false/0/no/off to disable.
# Also off when GC_MTPROTO_ENABLED=false. Use exactly ONE bot worker when enabled.
# GC_DM_GC_LISTENER_ENABLED=false

# Auto /gc new megagroups for unbound players: ON by default. Set false to only re-add players
# who already have a support_group_chats row (/bind or prior /gc). Listener stays on.
# GC_DM_GC_NEW_GROUPS_ENABLED=false

# Verbose dm_gc INFO (dm_capture, /gc_match, bootstrap). Default off — set true/1/yes for debugging.
# GC_DM_GC_VERBOSE_LOGS=true

# Telethon client reconnect tuning (listener + one-shot MTProto). Defaults match Telethon 1.38.
# GC_MTPROTO_CONNECTION_RETRIES=5
# GC_MTPROTO_RETRY_DELAY=1
# GC_MTPROTO_REQUEST_RETRIES=5
# GC_MTPROTO_AUTO_RECONNECT=true

# Supervised dm_gc listener: restart after disconnect (seconds, cap, multiplier).
# GC_DM_GC_LISTENER_RESTART_DELAY_SEC=5
# GC_DM_GC_LISTENER_RESTART_DELAY_MAX_SEC=120
# GC_DM_GC_LISTENER_RESTART_BACKOFF=2

# MTProto saves the sole non-admin / non-GC_USERS player as a contact (group title = name)
# after a successful bind rename, /track, or /info. Failures DM the club GC_ADMIN_USER_* in bot DM.
# Default on.
# GC_CONTACT_SAVE_ENABLED=false

# Migrated supergroup recovery cron (worker). Default off.
# GC_MIGRATION_RECOVERY_ENABLED=true
# GC_MIGRATION_RECOVERY_DISABLED_CLUBS=round_table   # skip RT; CC + GTO still run
# GC_MIGRATION_RECOVERY_ROUND_TABLE=false          # per-club off (same as list above)
# GC_MIGRATION_RECOVERY_CREATOR_CLUB=true
# GC_MIGRATION_RECOVERY_CLUB_GTO=true
# GC_MIGRATION_RECOVERY_BATCH_SIZE=5
# GC_MIGRATION_RECOVERY_INTERVAL_SEC=300
# GC_MIGRATION_RECOVERY_SKIP_WELCOME=true
# GC_MIGRATION_RECOVERY_SLACK_SUMMARY_INTERVAL_SEC=86400
# GC_MIGRATION_RECOVERY_SLACK_SUMMARY_ENABLED=true
# GC_MIGRATION_RECOVERY_RATE_LIMIT_COOLDOWN_SEC=3600   # after FloodWait ends

# Optional: shared fallback bot username for invites when the bot profile has no @username.
# GC_BOT_ACCOUNT=@YourSupportBotUsername

# Per-club /gc overrides — see README "MTProto /gc (support megagroups)".
# Defaults map support accounts to Round Table / Creator Club / ClubGTO and paths under ./sessions/.
# Examples:
# GC_ADMIN_USER_ROUND_TABLE=6713100304
# GC_SESSION_ROUND_TABLE=sessions/round_table.session
# Optional: prefill MTProto account phone for Dashboard login (E.164-style, +country…).
# Omit to type the number in Telegram login instead.
# MT_PROTO_PHONE_ROUND_TABLE=+1...
# MT_PROTO_PHONE_CREATOR_CLUB=+1...
# MT_PROTO_PHONE_CLUB_GTO=+1...
# GC_USERS_ROUND_TABLE=@teammate1,@teammate2
# GC_GROUP_PHOTO_ROUND_TABLE=assets/group_photos/round_table.jpg
# Megagroup titles are built as: RT/CC/GTO " / / " plus player (@username / name / "New Player").
# GC_GROUP_TITLE_* is retained for backward compatibility but not used for CreateChannel titles.
# GC_GROUP_TITLE_ROUND_TABLE=RT / New Player
#
# Override dashboard ``clubs.id`` for /gc auto-link + bot intro bundle (built-in defaults: RT=2, CC=3, GTO=4).
# GC_LINK_CLUB_ID_ROUND_TABLE=2
# GC_LINK_CLUB_ID_CREATOR_CLUB=3
# GC_LINK_CLUB_ID_CLUB_GTO=4

# Elevate Admin — Round Table megagroup creator (optional; default off).
# When true: Elevate Admin creates new RT groups; the Round Table MTProto session
# (@RoundTableSupport2 — same account as the DM listener) joins via invite link
# automatically and is promoted to admin. Log in Elevate Admin on Dashboard
# → Telegram login before enabling. Round Table listener login is unchanged.
# GC_ELEVATE_CREATOR_ROUND_TABLE=false
# GC_SESSION_ELEVATE_ADMIN=sessions/elevate_admin.session
# MT_PROTO_PHONE_ELEVATE_ADMIN=+1...
# GC_PROMOTE_ADMIN_ROUND_TABLE=@RoundTableSupport2
# GC_LINK_JOIN_EXCLUDE_ROUND_TABLE=@RoundTableSupport2

# Stripe debit-card deposits (/deposit when payment method slug is stripe)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_TEST_SECRET_KEY=sk_test_...   # optional: used by run_test_bot.py instead of live key
# STRIPE_ZAPIER_LOOKUP_SECRET=generate-a-long-random-string
# STRIPE_WEBHOOK_SECRET=whsec_...   # Stripe Dashboard → Webhooks → signing secret
# STRIPE_CHECKOUT_SUCCESS_URL=https://example.com/deposit-thanks
# STRIPE_CHECKOUT_CANCEL_URL=https://example.com/deposit-cancelled

# ClubGG auto chip-adding on /add (per-club toggle in dashboard: "Auto chip adding on /add")
# When both BASE_URL and TOKEN are set AND a club has the toggle on, an admin /add in a
# linked group also POSTs a deposit to the ClubGG deposit bot. Leave unset to disable for all.
# GG_DEPOSIT_API_BASE_URL=https://your-tunnel.trycloudflare.com
# GG_DEPOSIT_API_TOKEN=the-long-random-secret-from-server.json
# GG_DEPOSIT_API_DRY_RUN=true            # verify only, never press Enter (use for first rollout)
# /add 500 50 sends two deposits: 500 then 50 (separate request_ids; bonus only if parsed)
# GG_DEPOSIT_API_ALERT_CHAT_ID=-1001234567890   # Telegram chat for staff alerts (failures etc.)
# GG_DEPOSIT_API_ALERT_ON_SUCCESS=false  # also alert on success/dry-run (default: problems only)
# GG_DEPOSIT_API_EXPECTED_HOST=DESKTOP-T4K01J6   # optional identity guard (see deposit bot §7)
# GG_DEPOSIT_API_EXPECTED_PROFILE=edaad-pc       # optional identity guard
# GG_DEPOSIT_API_UNION_MAX_AGE_HOURS=24  # logs "stale union" when older; stale RT/AT still used
# GG_DEPOSIT_API_TIMEOUT_SEC=10
# GG_DEPOSIT_API_POLL_INTERVAL_SEC=3
# GG_DEPOSIT_API_POLL_TIMEOUT_SEC=180

# Payment notifications (all types — Venmo, Cashapp, Zelle, etc.)
# TELEGRAM_NOTIFICATION_BOT_TOKEN=your_ggnotificationbot_token
# PAYMENT_NOTIFICATION_CHAT_ID=-1001234567890
# VENMO_ZAPIER_WEBHOOK_SECRET=generate-a-long-random-string
# ZELLE_ZAPIER_WEBHOOK_SECRET=generate-a-long-random-string
# CASHAPP_ZAPIER_WEBHOOK_SECRET=generate-a-long-random-string
# PAYPAL_ZAPIER_WEBHOOK_SECRET=generate-a-long-random-string
# CRYPTO_ZAPIER_WEBHOOK_SECRET=generate-a-long-random-string
# DEBUG_NOTIFICATION=true   # verbose venmo ingest + telegram send logs on web dyno
# LINKED_GROUP_CHAT_HYPERLINKS_ENABLED=true   # hyperlink bound group title in payment notifications (default on)

# Slack ops alerts (migration re-add errors, notification /report tickets)
# Preferred: custom Slack app (e.g. Engineer noti service) via chat.postMessage
# SLACK_OPS_BOT_TOKEN=xoxb-...          # Bot User OAuth Token from api.slack.com/apps
# SLACK_OPS_CHANNEL_ID=C0123456789      # Channel ID where the app is installed
# SLACK_OPS_MENTION=<@U01234567>        # optional @JZ ping prefix in message text
# Fallback: Incoming Webhook (optional if bot token + channel are set)
# SLACK_OPS_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# Issue reports (/report, /escalate) — separate Slack app + channel
# SLACK_ISSUE_REPORT_BOT_TOKEN=xoxb-...
# SLACK_ISSUE_REPORT_CHANNEL_ID=C0123456789
# SLACK_ISSUE_REPORT_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
# ISSUE_REPORT_TAG_MENTIONS={"head_admin":"<!subteam^S_HEAD>","engineer":"<!subteam^S_ENG>","rb_admin":"<!subteam^S_RB>"}

# Admin /refresh — restart all Heroku dynos (DM only, ADMIN_USER_IDS)
# HEROKU_API_KEY=your_heroku_account_api_token 
# HEROKU_APP_NAME=gg-support-bot-2025

# Dashboard (API)
DASHBOARD_PASSWORD=changeme
# Early rakeback sync from aon-beta (pull + inbound webhook auth)
# AON_BETA_BASE_URL=https://aon-beta-production.up.railway.app/api
# AON_BETA_INTERNAL_API_KEY=shared-secret-with-aon-beta-INTERNAL_API_KEY
# Payments → Venmo: list/unbind group_payment_method_bindings (JWT; same DATABASE_URL as bot)
