# Copy to .env — never commit real secrets.

# Core
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Optional: second bot for live /deposit testing in a private group (python run_test_bot.py).
# Reads club_payment_* (v2) config; does not run MTProto dm_gc listener.
TELEGRAM_TEST_BOT_TOKEN=your_test_bot_token_from_botfather
# TEST_BOT_TOKEN=...   # alias for TELEGRAM_TEST_BOT_TOKEN
# BOT_USE_PAYMENT_V2=1   # default: club_payment_* (v2). Set to 0 to use legacy payment_* tables.

# GGCashier (staff cashout wizard) — separate bot from BotFather
TELEGRAM_CASHIER_BOT_TOKEN=your_cashier_bot_token_from_botfather

# Zapier → Glide Cashouts (GGCashier completion). Omit in dev to skip POST.
# ZAPIER_CASHOUT_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/20524789/4ogfszq/

# Bot worker stderr logging (defaults to INFO — support bot + GGCashier cashier worker)
# LOG_LEVEL=INFO

# GGCashier: extra DEBUG lines for every callback + conversation state (default off)
# CASHIER_VERBOSE_LOGS=true

# Telegram MTProto (User API) — required for /gc group creation via Telethon
# Create an app at https://my.telegram.org/apps
TG_API_ID=12345678
TG_API_HASH=your_api_hash_here

# Outgoing /gc in admin→player DMs: ON by default. Set false/0/no/off to disable.
# Use exactly ONE bot worker (same MTProto session must not connect twice).
# GC_DM_GC_LISTENER_ENABLED=false

# Verbose dm_gc INFO (dm_capture, /gc_match, bootstrap). Default off — set true/1/yes for debugging.
# GC_DM_GC_VERBOSE_LOGS=true

# Telethon client reconnect tuning (listener + one-shot MTProto). Defaults match Telethon 1.38.
# GC_MTPROTO_CONNECTION_RETRIES=5
# GC_MTPROTO_RETRY_DELAY=1
# GC_MTPROTO_REQUEST_RETRIES=5
# GC_MTPROTO_AUTO_RECONNECT=true

# Supervised dm_gc listener: restart after disconnect (seconds, cap, multiplier).
# GC_DM_GC_LISTENER_RESTART_DELAY_SEC=5
# GC_DM_GC_LISTENER_RESTART_DELAY_MAX_SEC=120
# GC_DM_GC_LISTENER_RESTART_BACKOFF=2

# MTProto saves the sole non-admin / non-GC_USERS player as a contact (group title = name)
# after a successful bind rename, /track, or /info. Failures DM the club GC_ADMIN_USER_* in bot DM.
# Default on.
# GC_CONTACT_SAVE_ENABLED=false

# Optional: shared fallback bot username for invites when the bot profile has no @username.
# GC_BOT_ACCOUNT=@YourSupportBotUsername

# Per-club /gc overrides — see README "MTProto /gc (support megagroups)".
# Defaults map support accounts to Round Table / Creator Club / ClubGTO and paths under ./sessions/.
# Examples:
# GC_ADMIN_USER_ROUND_TABLE=6713100304
# GC_SESSION_ROUND_TABLE=sessions/round_table.session
# Optional: prefill MTProto account phone for Dashboard login (E.164-style, +country…).
# Omit to type the number in Telegram login instead.
# MT_PROTO_PHONE_ROUND_TABLE=+1...
# MT_PROTO_PHONE_CREATOR_CLUB=+1...
# MT_PROTO_PHONE_CLUB_GTO=+1...
# GC_USERS_ROUND_TABLE=@teammate1,@teammate2
# GC_GROUP_PHOTO_ROUND_TABLE=assets/group_photos/round_table.jpg
# Megagroup titles are built as: RT/CC/GTO " / / " plus player (@username / name / "New Player").
# GC_GROUP_TITLE_* is retained for backward compatibility but not used for CreateChannel titles.
# GC_GROUP_TITLE_ROUND_TABLE=RT / New Player
#
# Override dashboard ``clubs.id`` for /gc auto-link + bot intro bundle (built-in defaults: RT=2, CC=3, GTO=4).
# GC_LINK_CLUB_ID_ROUND_TABLE=2
# GC_LINK_CLUB_ID_CREATOR_CLUB=3
# GC_LINK_CLUB_ID_CLUB_GTO=4

# Stripe debit-card deposits (/deposit when payment method slug is stripe)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_TEST_SECRET_KEY=sk_test_...   # optional: used by run_test_bot.py instead of live key
# STRIPE_ZAPIER_LOOKUP_SECRET=generate-a-long-random-string
# STRIPE_WEBHOOK_SECRET=whsec_...   # Stripe Dashboard → Webhooks → signing secret
# STRIPE_CHECKOUT_SUCCESS_URL=https://example.com/deposit-thanks
# STRIPE_CHECKOUT_CANCEL_URL=https://example.com/deposit-cancelled

# Payment notifications (all types — Venmo, Cashapp, Zelle, etc.)
# TELEGRAM_NOTIFICATION_BOT_TOKEN=your_ggnotificationbot_token
# PAYMENT_NOTIFICATION_CHAT_ID=-1001234567890
# VENMO_ZAPIER_WEBHOOK_SECRET=generate-a-long-random-string

# Dashboard (API)
DASHBOARD_PASSWORD=changeme

# Optional: second bot for live /deposit testing in a private group (python run_test_bot.py).
# Reads club_payment_* (v2) config; does not run MTProto dm_gc listener.
TELEGRAM_TEST_BOT_TOKEN=your_test_bot_token_from_botfather
